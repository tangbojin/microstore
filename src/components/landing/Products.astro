            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn prev" data-target="second-carousel">❮</button>
      <button class="carousel-btn next" data-target="second-carousel">❯</button>
    </div>
  </div>

  <!-- 第三组轮播 -->
