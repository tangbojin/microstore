<!-- 页面主体：一行展示 3 个轮播 -->
<div class="page-container">
  <!-- 第一组轮播 -->
  <div class="carousel-wrapper">
    <div class="carousel-container" id="first-carousel">
      <div class="carousel">
        {tag.map((product, index) => (
          <div class="carousel-item" id={`slide-${index}`}>
            <a href={product.url} class="absolute inset-0 z-10 touch-target"></a>
            <Image 
              width="336" 
              height="300" 
              loading="lazy"
              alt={product.title} 
              src={product.image} 
              class="w-full rounded-3xl shadow aspect-12/9 object-cover object-center" 
            />
            <div class="mt-2 flex justify-between px-6 relative z-20">
              <div>
                <p class="mt-1 text-sm font-medium text-base-900">{product.subtitle}</p>
                <h3 class="custom-title ">{product.title}</h3>
              </div>
              <p class="text-base text-orange-600">{product.price}</p>
            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn prev" data-target="first-carousel" aria-label="Previous">❮</button>
      <button class="carousel-btn next" data-target="first-carousel" aria-label="Next">❯</button>
    </div>
  </div>

