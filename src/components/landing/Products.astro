              height="300" 
              loading="lazy"
              alt={product.title} 
              src={product.image} 
              class="w-full rounded-3xl shadow aspect-12/9 object-cover object-center" 
            />
            <div class="mt-2 flex justify-between px-6 relative z-20">
              <div>
                <p class="mt-1 text-sm font-medium text-base-900">{product.subtitle}</p>
                <h3 class="custom-title ">{product.title}</h3>
              </div>
              <p class="text-base text-orange-600">{product.price}</p>
            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn prev" data-target="seventh-carousel" aria-label="Previous">❮</button>
      <button class="carousel-btn next" data-target="seventh-carousel" aria-label="Next">❯</button>
    </div>
  </div>

  <!-- 第八组轮播 -->
  <div class="carousel-wrapper">
    <div class="carousel-container" id="eighth-carousel">
      <div class="carousel">
        {zipaigan.map((product, index) => (
          <div class="carousel-item" id={`eighth-slide-${index}`}>
            <a href={product.url} class="absolute inset-0 z-10 touch-target"></a>
            <Image 
              width="336" 
              height="300" 
              loading="lazy"
              alt={product.title} 
              src={product.image} 
              class="w-full rounded-3xl shadow aspect-12/9 object-cover object-center" 
            />
            <div class="mt-2 flex justify-between px-6 relative z-20">
              <div>
                <p class="mt-1 text-sm font-medium text-base-900">{product.subtitle}</p>
                <h3 class="custom-title ">{product.title}</h3>
              </div>
              <p class="text-base text-orange-600">{product.price}</p>
            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn prev" data-target="eighth-carousel" aria-label="Previous">❮</button>
      <button class="carousel-btn next" data-target="eighth-carousel" aria-label="Next">❯</button>
    </div>
  </div>
</div>

<style>
  .page-container {
    display: flex;
    gap: 20px;
    padding: 20px;
  }

  .carousel-wrapper {
    flex: 1;
    max-width: 33.33%;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .carousel {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .carousel-item {
    min-width: 100%;
    box-sizing: border-box;
    padding: 0 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .carousel-item img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .carousel-item a {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
    transition: background 0.3s ease;
  }

  .carousel-item:hover a {
    background: rgba(0, 0, 0, 0.1);
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    padding: 10px;
    cursor: pointer;
    z-index: 10;
  }

  .prev {
    left: 10px;
  }

  .next {
    right: 10px;
  }

  /* 自定义标题样式 */
  .custom-title {
    font-size: 1rem;
    color: #ff6b6b;
    font-weight: bold;
    line-height: 1.4;
    word-wrap: break-word; /* 允许单词内换行 */
    white-space: normal;
    }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .page-container {
      flex-direction: column;
      padding: 10px;
      gap: 15px;
    }

    .carousel-wrapper {
      flex: 1;
      max-width: 100%;
      margin-bottom: 15px;
    }

    .carousel-container {
      width: 100%;
      margin: 0 auto;
    }

    .carousel-item {
      min-width: 85vw; /* 移动端单张卡片占屏幕宽度的85% */
      padding: 0 5px;
    }

    .carousel-item img {
      height: 220px;
      width: 100%;
    }

    .custom-title {
      font-size: 0.85rem;
      line-height: 1.3;
    }

    . {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .touch-target {
      /* 增加触摸目标大小 */
      min-height: 44px;
    }

    .carousel-btn {
      padding: 12px 10px;
      font-size: 1.2rem;
      background-color: rgba(0, 0, 0, 0.6);
    }

    .prev {
      left: 5px;
    }

    .next {
      right: 5px;
    }
  }

  @media (max-width: 480px) {
    .carousel-item {
      min-width: 90vw;
    }

    .carousel-item img {
      height: 200px;
    }

    .custom-title {
      font-size: 0.8rem;
    }

    .page-container {
      padding: 5px;
      gap: 10px;
    }
  }

  /* 为小屏幕进一步优化 */
  @media (max-width: 360px) {
    .carousel-item img {
      height: 180px;
    }

    .custom-title {
      font-size: 0.75rem;
    }

    .carousel-btn {
      padding: 10px 8px;
      font-size: 1rem;
    }
  }

  /* 防止横向滚动 */
  body {
    overflow-x: hidden;
  }
</style>

<script is:inline>
  // 移动端适配的轮播功能
  function moveSlide(targetId, direction) {
    const container = document.getElementById(targetId);
    const carousel = container.querySelector('.carousel');
    const slides = container.querySelectorAll('.carousel-item');
    
    // 计算当前可视区域能显示的卡片数量
    const containerWidth = container.clientWidth;
    const slideWidth = slides[0].clientWidth || containerWidth;
    const itemsPerView = Math.floor(containerWidth / slideWidth) || 1;
    const itemsPerPage = itemsPerView;
    
    const totalPages = Math.ceil(slides.length / itemsPerPage);
    let currentPage = parseInt(carousel.dataset.currentPage || 0);

    currentPage += direction;

    if (currentPage >= totalPages) {
      currentPage = 0;
    } else if (currentPage < 0) {
      currentPage = totalPages - 1;
    }

    const offset = currentPage * itemsPerPage * (100 / itemsPerPage);
    carousel.style.transform = `translateX(-${offset}%)`;
    carousel.dataset.currentPage = currentPage;
  }

  // 触摸滑动支持
  document.querySelectorAll('.carousel-container').forEach(container => {
    let startX = 0;
    let endX = 0;
    
    container.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    });

    container.addEventListener('touchend', (e) => {
      endX = e.changedTouches[0].clientX;
      const diffX = startX - endX;
      
      if (Math.abs(diffX) > 50) { // 滑动距离大于50px才触发
        const targetId = container.id;
        if (diffX > 0) {
          // 向左滑动，显示下一张
          moveSlide(targetId, 1);
        } else {
          // 向右滑动，显示上一张
          moveSlide(targetId, -1);
        }
      }
    });
  });

  // 点击按钮事件
  document.querySelectorAll('.carousel-btn').forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target');
      const direction = button.classList.contains('prev') ? -1 : 1;
      moveSlide(targetId, direction);
    });
  });
</script>