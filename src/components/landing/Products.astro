  <!-- 第七组轮播 -->
  <div class="carousel-wrapper">
    <div class="carousel-container" id="seventh-carousel">
      <div class="carousel">
        {rutie.map((product, index) => (
          <div class="carousel-item" id={`seventh-slide-${index}`}>
            <a href={product.url} class="absolute inset-0 z-10"></a>
            <Image width="336" height="300" alt={product.title} src={product.image} class="w-full rounded-3xl shadow aspect-12/9 object-cover object-center" />
            <div class="mt-2 flex justify-between px-6 relative z-20">
              <div>
                <p class="mt-1 text-sm font-medium text-base-900">{product.subtitle}</p>
                <h3 class="custom-title">{product.title}</h3>
              </div>
              <p class="text-base text-orange-600">{product.price}</p>
            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn prev" data-target="seventh-carousel">❮</button>
      <button class="carousel-btn next" data-target="seventh-carousel">❯</button>
    </div>
  </div>

  <!-- 第八组轮播 -->
  <div class="carousel-wrapper">
    <div class="carousel-container" id="eighth-carousel">
      <div class="carousel">
        {zipaigan.map((product, index) => (
          <div class="carousel-item" id={`eighth-slide-${index}`}>
            <a href={product.url} class="absolute inset-0 z-10"></a>
            <Image width="336" height="300" alt={product.title} src={product.image} class="w-full rounded-3xl shadow aspect-12/9 object-cover object-center" />
            <div class="mt-2 flex justify-between px-6 relative z-20">
              <div>
                <p class="mt-1 text-sm font-medium text-base-900">{product.subtitle}</p>
                <h3 class="custom-title">{product.title}</h3>
              </div>
              <p class="text-base text-orange-600">{product.price}</p>
            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn prev" data-target="eighth-carousel">❮</button>
      <button class="carousel-btn next" data-target="eighth-carousel">❯</button>
    </div>
  </div>
</div>

<style>
  .page-container {
    display: flex;
    gap: 20px;
    padding: 20px;
  }

  .carousel-wrapper {
    flex: 1;
    max-width: 33.33%;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .carousel {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .carousel-item {
    min-width: 100%;
    box-sizing: border-box;
    padding: 0 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .carousel-item img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .carousel-item a {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
    transition: background 0.3s ease;
  }

  .carousel-item:hover a {
    background: rgba(0, 0, 0, 0.1);
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    padding: 10px;
    cursor: pointer;
    z-index: 10;
  }

  .prev {
    left: 10px;
  }

  .next {
    right: 10px;
  }

  /* 自定义标题样式 */
  .custom-title {
    font-size: 1rem; /* 字体大小 */
    color: #ff6b6b; /* 字体颜色 */
    font-weight: bold; /* 加粗 */
  }
</style>

<script is:inline>
  function moveSlide(targetId, direction) {
    const container = document.getElementById(targetId);
    const carousel = container.querySelector('.carousel');
    const slides = container.querySelectorAll('.carousel-item');
    const itemsPerPage = 1;
    const totalPages = Math.ceil(slides.length / itemsPerPage);
    let currentPage = parseInt(carousel.dataset.currentPage || 0);

    currentPage += direction;

    if (currentPage >= totalPages) {
      currentPage = 0;
    } else if (currentPage < 0) {
      currentPage = totalPages - 1;
    }

    const offset = currentPage * itemsPerPage * 100;
    carousel.style.transform = `translateX(-${offset}%)`;
    carousel.dataset.currentPage = currentPage;
  }

  document.querySelectorAll('.carousel-btn').forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target');
      const direction = button.classList.contains('prev') ? -1 : 1;
      moveSlide(targetId, direction);
    });
  });
</script>